# Anthropic API key (optional — if not set, OAuth login via browser is used)
ANTHROPIC_API_KEY=

# Per-session budget cap in USD. Applies only under API-key billing
# (OAuth/subscription sessions are turn-limited). Overridden by --max-budget.
# ADMIN_AGENT_MAX_BUDGET=5.00

# Kinetica connection details (prompted interactively if not set)
# If password is omitted, the agent will prompt for it at startup
KINETICA_URL=
KINETICA_USER=
KINETICA_PASS=

# Strict HTTPS mode — when set to 1, the agent refuses to fall back to
# plaintext HTTP after a failed HTTPS probe. Recommended for production.
# KINETICA_HTTPS_ONLY=1
